  "key_equations": [
    {
      "name": "Aerobic Respiration",
      "equation": "C6H12O6 + 6O2 → 6CO2 + 6H2O + ATP"
    },
    {
      "name": "Photosynthesis",
      "equation": "6CO2 + 6H2O → C6H12O6 + 6O2 (light energy + chlorophyll)"
    },
    {
      "name": "Anaerobic Respiration (humans)",
      "equation": "C6H12O6 → 2C3H6O3 + small amount of ATP"
    },
    {
      "name": "Anaerobic Respiration (yeast)",
      "equation": "C6H12O6 → 2C2H5OH + 2CO2 + small amount of ATP"
    }
  ],
  "key_definitions": [
    {
      "term": "Diffusion",
      "definition": "Net movement of molecules from a region of higher concentration to lower concentration, down a concentration gradient, by random movement. No energy required."
    },
    {
      "term": "Osmosis",
      "definition": "Net movement of water molecules through a partially permeable membrane from a region of higher water potential (dilute) to lower water potential (concentrated). No energy required."
    },
    {
      "term": "Active Transport",
      "definition": "Movement of molecules or ions against a concentration gradient, across a cell membrane, using energy (ATP) and carrier proteins."
    },
    {
      "term": "Enzyme",
      "definition": "A protein that acts as a biological catalyst, speeding up metabolic reactions without being permanently changed."
    },
    {
      "term": "Homeostasis",
      "definition": "The maintenance of a constant internal environment despite external changes."
    },
    {
      "term": "Natural Selection",
      "definition": "Process by which organisms best adapted to their environment are more likely to survive, reproduce, and pass on their beneficial alleles to the next generation."
    },
    {
      "term": "Genetic Modification",
      "definition": "Changing the genetic material of an organism by removing, changing, or inserting individual genes from another organism."
    },
    {
      "term": "Photosynthesis",
      "definition": "The process by which green plants use light energy, carbon dioxide, and water to produce glucose and oxygen."
    },
    {
      "term": "Respiration",
      "definition": "The chemical process in cells that releases energy from organic molecules (mainly glucose) for metabolic use."
    },
    {
      "term": "Excretion",
      "definition": "The removal from the body of the waste products of metabolism."
    }
  ],
  "food_tests": [
    {
      "substance": "Starch",
      "reagent": "Iodine solution",
      "positive_result": "Blue-black colour",
      "negative_result": "Yellow-brown (unchanged)"
    },
    {
      "substance": "Reducing sugars (glucose, maltose)",
      "reagent": "Benedict's solution + heat",
      "positive_result": "Brick-red precipitate",
      "negative_result": "Remains blue"
    },
    {
      "substance": "Protein",
      "reagent": "Biuret reagent (NaOH + CuSO4)",
      "positive_result": "Purple/violet colour",
      "negative_result": "Remains blue"
    },
    {
      "substance": "Lipid (fat)",
      "reagent": "Ethanol emulsion test",
      "positive_result": "White milky emulsion",
      "negative_result": "Clear liquid"
    }
  ],
